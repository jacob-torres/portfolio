---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jacob A. Torres">
  <section class="hero">
    <div class="hero-image">
      <img
        src="/assets/img/red-shirt-picture.jpg"
        alt="Jacob Torres standing outside in a red button-up shirt."
        width="180"
        height="180"
      />
    </div>
    <div class="hero-text">
      <h1>Jacob A. Torres</h1>
      <p>
        I study data science, machine learning, and linguistics at MSU Denver.
        I'm a self-starting tech enthusiast with a passion for language and
        digital accessibility. I also occasionally write short fiction.
      </p>
      <a href="mailto:contact@jacobtorres.net" class="button">Contact me</a>
    </div>
  </section>

  <div class="home-features">
    <div class="feature-card">
      <h2>Machine Learning</h2>
      <p>
        Python and machine learning — building intelligent applications with
        neural networks and data science libraries.
      </p>
      <a href="/machine-learning">View my projects &rarr;</a>
    </div>
    <div class="feature-card">
      <h2>Web Development</h2>
      <p>
        Accessible UI development with HTML, CSS, JavaScript/TypeScript,
        Django, and Flask — over 5 years of building applications.
      </p>
      <a href="/web-development">View my projects &rarr;</a>
    </div>
  </div>
</Layout>
