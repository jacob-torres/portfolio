---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jacob A. Torres">
  <section class="hero">
    <div class="hero-image">
      <img
        src="https://jacobtorres.net/wp-content/uploads/2024/04/red-shirt-picture.jpg"
        alt="Jacob Torres standing outside in a red button-up shirt."
        width="180"
        height="180"
      />
    </div>
    <div class="hero-text">
      <h1>Jacob A. Torres</h1>
      <p>
        I study data science, machine learning, and linguistics at MSU Denver.
        I'm a self-starting tech enthusiast with a passion for language and
        digital accessibility. I also occasionally write short fiction.
      </p>
      <a href="mailto:jacob.torres1229@gmail.com" class="button">Contact me</a>
    </div>
  </section>

  <div class="home-features">
    <div class="feature-card">
      <h2>Programming</h2>
      <p>
        Python, JavaScript, machine learning, and web development — over 5 years
        of building applications.
      </p>
      <a href="/programming">View my projects &rarr;</a>
    </div>
    <div class="feature-card">
      <h2>Accessibility</h2>
      <p>
        As a blind tech user, I'm passionate about making the web work for
        everyone. I offer WCAG audits and consulting.
      </p>
      <a href="https://github.com/jacob-torres" rel="external noopener"
        >GitHub &rarr;</a
      >
    </div>
  </div>
</Layout>
